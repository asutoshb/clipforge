# ClipForge configuration (copy to .env and edit)

# LLM provider: "local" (Ollama, free) or "openai" (cloud)
CLIPFORGE_LLM_PROVIDER=local

# Local LLM via Ollama (default). Run: `ollama pull llama3.1`
CLIPFORGE_OLLAMA_HOST=http://localhost:11434
CLIPFORGE_OLLAMA_MODEL=llama3.1

# Optional cloud (only if provider=openai)
# OPENAI_API_KEY=sk-...
CLIPFORGE_OPENAI_MODEL=gpt-4o-mini

# Transcription (faster-whisper). Models: tiny, base, small, medium, large-v3
CLIPFORGE_WHISPER_MODEL=base
CLIPFORGE_WHISPER_DEVICE=cpu

# Storage locations (relative to project root)
CLIPFORGE_STORAGE_DIR=storage

# Safety: only allow downloads you have rights to (owned / Creative Commons)
CLIPFORGE_DOWNLOAD_DISCLAIMER_ACK=false
